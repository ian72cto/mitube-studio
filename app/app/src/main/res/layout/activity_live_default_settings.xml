<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E1E">

    <!-- Custom Action Bar Area -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="#2E2E2E">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"
            android:text="MiTube Live 기본 설정"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="뒤로 가기 및 저장"/>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

        <!-- General Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="카테고리"
            android:textColor="#AAAAAA"
            android:textSize="14sp"/>
        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:spinnerMode="dialog"
            android:backgroundTint="#AAAAAA"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="재생목록 선택"
            android:textColor="#AAAAAA"
            android:textSize="14sp"/>
        <Button
            android:id="@+id/btnPlaylist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="재생목록 선택 안함"
            android:backgroundTint="#333333"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#444444" android:layout_marginBottom="24dp"/>

        <!-- Kids -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="시청자층 (아동용 여부)"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>
        <RadioGroup
            android:id="@+id/rgKids"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">
            <RadioButton
                android:id="@+id/rbKidsYes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="예, 아동용입니다"
                android:textColor="#FFFFFF"
                android:buttonTint="#3EA6FF"/>
            <RadioButton
                android:id="@+id/rbKidsNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="아니요, 아동용이 아닙니다"
                android:textColor="#FFFFFF"
                android:checked="true"
                android:buttonTint="#3EA6FF"/>
        </RadioGroup>

        <!-- Latency -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="스트림 지연 시간"
            android:textColor="#AAAAAA"
            android:textSize="14sp"/>
        <RadioGroup
            android:id="@+id/rgLatency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">
            <RadioButton
                android:id="@+id/rbLatencyNormal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="기본 지연 시간"
                android:textColor="#FFFFFF"
                android:checked="true"
                android:buttonTint="#3EA6FF"/>
            <RadioButton
                android:id="@+id/rbLatencyLow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="짧은 지연 시간"
                android:textColor="#FFFFFF"
                android:buttonTint="#3EA6FF"/>
            <RadioButton
                android:id="@+id/rbLatencyUltra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="매우 짧은 지연 시간"
                android:textColor="#FFFFFF"
                android:buttonTint="#3EA6FF"/>
        </RadioGroup>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#444444" android:layout_marginBottom="24dp"/>

        <!-- Advanced Switches -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="고급 기능"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>
        
        <CheckBox
            android:id="@+id/cbDvr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DVR (타임시프트) 사용 (기본 Unchecked)"
            android:textColor="#FFFFFF"
            android:checked="false"
            android:buttonTint="#3EA6FF"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ 주의: 이 기능을 체크할 경우 시청자간 영상 시점이 다를 수 있습니다."
            android:textColor="#FF6B6B"
            android:textSize="12sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="16dp"/>

        <CheckBox
            android:id="@+id/cb360"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="360도 동영상 (현재 지원 안함)"
            android:textColor="#888888"
            android:checked="false"
            android:enabled="false"
            android:buttonTint="#555555"
            android:layout_marginBottom="16dp"/>

        <CheckBox
            android:id="@+id/cbPaidPromo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="유료 프로모션 포함"
            android:textColor="#FFFFFF"
            android:buttonTint="#3EA6FF"
            android:layout_marginBottom="8dp"/>
            
        <CheckBox
            android:id="@+id/cbAlteredContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="변경된 콘텐츠 (AI 생성 등)"
            android:textColor="#FFFFFF"
            android:buttonTint="#3EA6FF"
            android:layout_marginBottom="8dp"/>
            
        <CheckBox
            android:id="@+id/cbAutoChapters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="자동 챕터 허용"
            android:textColor="#FFFFFF"
            android:buttonTint="#3EA6FF"
            android:layout_marginBottom="8dp"/>
            
        <CheckBox
            android:id="@+id/cbPlaces"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="동영상 속 장소 표시"
            android:textColor="#FFFFFF"
            android:buttonTint="#3EA6FF"
            android:layout_marginBottom="8dp"/>
            
        <CheckBox
            android:id="@+id/cbConcepts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="개념 설명 자동 제공"
            android:textColor="#FFFFFF"
            android:buttonTint="#3EA6FF"
            android:layout_marginBottom="24dp"/>

        <!-- Embed & Interactivity -->
        <CheckBox
            android:id="@+id/cbEmbed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="퍼가기 허용"
            android:textColor="#FFFFFF"
            android:checked="true"
            android:buttonTint="#3EA6FF"
            android:layout_marginBottom="8dp"/>

        <CheckBox
            android:id="@+id/cbShowLikes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="스트림에 좋아요를 표시한 시청자수 표시"
            android:textColor="#FFFFFF"
            android:checked="true"
            android:buttonTint="#3EA6FF"
            android:layout_marginBottom="24dp"/>

        <!-- Caption Certification -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="언어 자막 면제 인증서"
            android:textColor="#AAAAAA"
            android:textSize="14sp"/>
        <Spinner
            android:id="@+id/spinnerCaption"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:spinnerMode="dialog"
            android:backgroundTint="#AAAAAA"
            android:layout_marginBottom="24dp"/>

        <!-- Comments Setting -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="댓글 및 평가 설정"
            android:textColor="#AAAAAA"
            android:textSize="14sp"/>
        <Spinner
            android:id="@+id/spinnerComments"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:spinnerMode="dialog"
            android:backgroundTint="#AAAAAA"
            android:layout_marginBottom="32dp"/>

        <!-- Bottom Chat Defaults (Can be overridden in reservation) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="실시간 채팅 (기본 활성화/다시보기 설정)"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>
        <CheckBox
            android:id="@+id/cbChat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="실시간 채팅 사용"
            android:textColor="#FFFFFF"
            android:checked="true"
            android:buttonTint="#3EA6FF"/>
        <CheckBox
            android:id="@+id/cbChatReplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="실시간 채팅 다시보기"
            android:textColor="#FFFFFF"
            android:checked="true"
            android:buttonTint="#3EA6FF"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>
    </ScrollView>
</LinearLayout>
